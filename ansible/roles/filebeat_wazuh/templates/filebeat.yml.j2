filebeat.inputs:
  - type: filestream
    id: wazuh-alerts
    enabled: true
    paths:
      - /var/ossec/logs/alerts/alerts.json
    parsers:
      - ndjson:
          overwrite_keys: true
          add_error_key: true
    # Resiliencia ante rotación diaria + restart del manager (cambio de inodo).
    # Sin esto filebeat se queda colgado del inodo viejo y deja de leer.
    prospector:
      scanner:
        check_interval: 10s
    close:
      on_state_change:
        inactive: 5m
        renamed: true
        removed: true
    ignore_older: 24h
    clean_inactive: 26h

output.logstash:
  hosts: ["{{ logstash_host }}"]
