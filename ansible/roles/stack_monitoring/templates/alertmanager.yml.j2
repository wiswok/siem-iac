global:
  resolve_timeout: 5m

route:
  group_by: ["alertname", "instance"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: "telegram"
  routes:
    - matchers:
        - severity = "critical"
      receiver: "telegram"
      repeat_interval: 1h

receivers:
  - name: "telegram"
    telegram_configs:
      - bot_token: "{{ telegram_bot_token }}"
        chat_id: {{ telegram_chat_id }}
        parse_mode: "HTML"
        send_resolved: true
        message: |-
          {% raw %}{{ if eq .Status "firing" }}{{ range .Alerts }}
          {{ if eq .Labels.severity "critical" }}🔴{{ else }}🟡{{ end }} <b>[{{ if eq .Labels.categoria "siem" }}SIEM{{ else }}INFRA{{ end }}] {{ .Labels.alertname }}</b>
          📌 <b>Resumen:</b> {{ .Annotations.summary }}
          📊 <b>Valor:</b> {{ .Annotations.value }}
          {{ if .Labels.node }}📍 <b>Nodo:</b> {{ .Labels.node }}
          {{ end }}{{ if .Labels.service }}🛠 <b>Servicio:</b> {{ .Labels.service }}
          {{ end }}{{ if .Labels.mountpoint }}💾 <b>Mount:</b> {{ .Labels.mountpoint }}
          {{ end }}⚠️ <b>Severidad:</b> {{ .Labels.severity | toUpper }}
          🕒 <b>Inicio:</b> {{ .StartsAt.Format "02/01 15:04:05 MST" }}
          📝 {{ .Annotations.description }}{{ if .Labels.node }}
          📈 <a href="{% endraw %}{{ grafana_public_url }}{% raw %}/d/node-infra?var-node={{ .Labels.node }}&from=now-1h&to=now">Ver en Grafana</a>{{ end }}{{ if eq .Labels.alertname "CertificadoProximoCaducar" }}
          🔐 <a href="{% endraw %}{{ prometheus_public_url }}{% raw %}/graph?g0.expr=(probe_ssl_earliest_cert_expiry%7Bmonitor_cert%3D%22true%22%7D%20-%20time())%20%2F%203600&g0.tab=0">Ver certificados en Prometheus</a>{{ end }}
          {{ end }}{{ else }}{{ range .Alerts }}
          ✅ <b>[{{ if eq .Labels.categoria "siem" }}SIEM{{ else }}INFRA{{ end }}] {{ .Labels.alertname }} — RESUELTO</b>
          {{ if .Labels.node }}📍 <b>Nodo:</b> {{ .Labels.node }}
          {{ end }}{{ if .Labels.service }}🛠 <b>Servicio:</b> {{ .Labels.service }}
          {{ end }}🕒 <b>Inicio:</b> {{ .StartsAt.Format "02/01 15:04:05 MST" }}
          🕓 <b>Fin:</b> {{ .EndsAt.Format "02/01 15:04:05 MST" }}
          {{ end }}{{ end }}{% endraw %}

inhibit_rules:
  - source_matchers:
      - severity = "critical"
    target_matchers:
      - severity = "warning"
    equal: ["instance"]
