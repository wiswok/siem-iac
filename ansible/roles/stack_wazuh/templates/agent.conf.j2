<agent_config>

  <syscheck>
    <frequency>43200</frequency>

    <!-- kernel/grub rewritten on every apt upgrade -->
    <ignore type="sregex">^/boot/</ignore>

    <!-- regenerated by ldconfig after every apt install -->
    <ignore>/etc/ld.so.cache</ignore>

    <!-- snap rewrites unit-files on each package refresh -->
    <ignore type="sregex">^/etc/systemd/system/.*snap.*</ignore>

    <!-- runtime state, package caches, logs (no forensic value) -->
    <ignore>/var/lib/apt</ignore>
    <ignore>/var/lib/dpkg</ignore>
    <ignore>/var/cache</ignore>
    <ignore>/var/log</ignore>
    <ignore>/tmp</ignore>
    <ignore>/run</ignore>
    <ignore type="sregex">^/var/lib/docker/</ignore>
    <ignore type="sregex">^/var/lib/containerd/</ignore>
  </syscheck>

  <wodle name="syscollector">
    <disabled>no</disabled>
    <interval>10m</interval>
    <scan_on_start>yes</scan_on_start>
    <hardware>yes</hardware>
    <os>yes</os>
    <network>yes</network>
    <packages>yes</packages>
    <ports all="no">yes</ports>
    <processes>yes</processes>
  </wodle>

</agent_config>
