name: "Suricata - Alerta Crítica"
type: any
index: suricata-*

filter:
  - query:
      query_string:
        query: >
          event_type: alert AND (
            alert.severity: 1 OR
            alert.category: "A Network Trojan was detected" OR
            alert.category: "Malware Command and Control Activity Detected" OR
            alert.category: "Exploit Kit Activity Detected" OR
            alert.category: "Targeted Malicious Activity was Detected" OR
            alert.category: "Web Application Attack"
          )

realert:
  minutes: 10

alert_missing_value: "?"

alert: telegram
telegram_bot_token: "{{ telegram_bot_token }}"
telegram_room_id: "{{ telegram_chat_id }}"
telegram_parse_mode: html

alert_text_type: alert_text_only
alert_text: |
  🔴 <b>[SIEM] Alerta Crítica — Suricata</b>
  📌 <b>Resumen:</b> Firma de severidad crítica o categoría maliciosa detectada
  📋 <b>Firma:</b> {0}
  🗂 <b>Categoría:</b> {1}
  ⚠️ <b>Severidad:</b> {2}
  🌐 <b>Origen:</b> {3}:{4}
  🎯 <b>Destino:</b> {5}:{6}
  🔌 <b>Protocolo:</b> {7}
  🔍 <a href="{{ kibana_public_url }}/app/discover#/?_g=(time:(from:now-1h,to:now))&_a=(query:(language:kuery,query:'alert.signature:%22{0}%22'))">Ver en Kibana</a>
alert_text_args:
  - alert.signature
  - alert.category
  - alert.severity
  - src_ip
  - src_port
  - dest_ip
  - dest_port
  - proto
